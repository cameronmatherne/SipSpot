{
  "expo": {
    "name": "SipSpot",
    "slug": "sipspot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sipspot",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],

    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1120"
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sipspot.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SipSpot uses your location to show nearby happy hours and deals.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SipSpot uses your location to show nearby happy hours and deals."
      }
    },

    "android": {
      "package": "com.sipspot.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1120"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },

    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SipSpot uses your location to show nearby happy hours and deals."
        }
      ]
    ],

    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
